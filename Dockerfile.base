# rp-base — minimal image holding the rp-fuse binary, the init script, and
# the OS-level bits the rp overlay needs to layer onto any user-chosen image.
# Built via `rp build-base`. The default `robo-pen-default` image FROMs this;
# per-project images apply the same rp layer as a final stage atop a user's
# image of choice (see ADR-0006).

# ── Stage 1: build rp-fuse (Go) ─────────────────────────────────
FROM golang:1.22-alpine AS rp-fuse-build

WORKDIR /src
COPY rp-fuse/go.mod rp-fuse/go.sum ./
RUN go mod download
COPY rp-fuse/main.go rp-fuse/host_node.go rp-fuse/rules.go rp-fuse/lint.go rp-fuse/config.go rp-fuse/config_cmd.go rp-fuse/profile.go rp-fuse/profile_cmd.go ./
RUN CGO_ENABLED=0 go build -o /out/rp-fuse -ldflags "-s -w" .

# ── Stage 1b: build rp-init-bootstrap (Go setuid wrapper) ──────
# Tight setuid-root wrapper that lets a non-root caller exec
# /usr/local/bin/rp-init.sh as root. Required by Docker Sandbox-style
# runtimes where the container's default user is non-root and there's
# no equivalent of Apple Container's `--user 0` create flag. See ADR-0010.
FROM golang:1.22-alpine AS rp-init-bootstrap-build
WORKDIR /src
COPY rp-init-bootstrap/go.mod ./
COPY rp-init-bootstrap/main.go ./
RUN CGO_ENABLED=0 go build -o /out/rp-init-bootstrap -ldflags "-s -w" .

# ── Stage 2: rp-base runtime ────────────────────────────────────
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        fuse3 \
        locales \
    && sed -i 's/^# *\(en_US.UTF-8\)/\1/' /etc/locale.gen \
    && locale-gen \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# Default unprivileged user. Project images may adopt a different user via
# `user:` in .rp/config.yaml; rp enforces uid ≠ 0 + no sudoers entry.
RUN useradd -m -s /bin/bash -u 1000 coder

# Allow non-root processes to access the FUSE mount with allow_other.
RUN sed -i 's/^#user_allow_other/user_allow_other/' /etc/fuse.conf 2>/dev/null \
    || echo 'user_allow_other' >> /etc/fuse.conf

COPY --from=rp-fuse-build /out/rp-fuse /usr/local/bin/rp-fuse
COPY --from=rp-init-bootstrap-build /out/rp-init-bootstrap /usr/local/bin/rp-init-bootstrap
COPY config/rp-init.sh /usr/local/bin/rp-init.sh

# Agent-agnostic container fundamentals fragment. The overlay copies this
# into the project image so every container's composed agent instructions
# include the basics (workspace layout, no-sudo, etc.).
COPY config/00-container.md /etc/rp/instructions/00-container.md

# rp-init-bootstrap is setuid root so a non-root caller can execve it to
# bootstrap the FUSE mount (ADR-0010). rp-fuse + rp-init.sh stay 0755 —
# they're invoked via the bootstrap, never directly by an unprivileged user.
RUN chmod 0755 /usr/local/bin/rp-fuse /usr/local/bin/rp-init.sh \
    && chown root:root /usr/local/bin/rp-init-bootstrap \
    && chmod 4755 /usr/local/bin/rp-init-bootstrap \
    && mkdir -p /var/lib/rp/shadow /var/lib/rp/backing /workspace /workspace-real /usr/local/lib/rp \
    && chmod 0700 /var/lib/rp \
    && chown root:root /var/lib/rp /var/lib/rp/shadow /var/lib/rp/backing

WORKDIR /workspace
